{
  "name": "skillpack",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "skillpack",
      "workspaces": [
        "packages/*"
      ],
      "engines": {
        "node": ">=18"
      }
    },
    "node_modules/@skillpack/cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/@skillpack/skill-debug": {
      "resolved": "packages/skill-debug",
      "link": true
    },
    "node_modules/@skillpack/skill-handoff": {
      "resolved": "packages/skill-handoff",
      "link": true
    },
    "node_modules/@skillpack/skill-refactor": {
      "resolved": "packages/skill-refactor",
      "link": true
    },
    "node_modules/@skillpack/skill-review": {
      "resolved": "packages/skill-review",
      "link": true
    },
    "node_modules/@skillpack/skill-sdd": {
      "resolved": "packages/skill-sdd",
      "link": true
    },
    "packages/cli": {
      "name": "@skillpack/cli",
      "version": "0.1.0",
      "license": "MIT",
      "bin": {
        "skillpack": "bin/skillpack.js"
      },
      "engines": {
        "node": ">=18"
      }
    },
    "packages/skill-debug": {
      "name": "@skillpack/skill-debug",
      "version": "1.0.0",
      "license": "MIT",
      "engines": {
        "node": ">=18"
      }
    },
    "packages/skill-handoff": {
      "name": "@skillpack/skill-handoff",
      "version": "1.0.0",
      "license": "MIT",
      "engines": {
        "node": ">=18"
      }
    },
    "packages/skill-refactor": {
      "name": "@skillpack/skill-refactor",
      "version": "1.0.0",
      "license": "MIT",
      "engines": {
        "node": ">=18"
      }
    },
    "packages/skill-review": {
      "name": "@skillpack/skill-review",
      "version": "1.0.0",
      "license": "MIT",
      "engines": {
        "node": ">=18"
      }
    },
    "packages/skill-sdd": {
      "name": "@skillpack/skill-sdd",
      "version": "1.0.0",
      "license": "MIT",
      "engines": {
        "node": ">=18"
      }
    }
  }
}
