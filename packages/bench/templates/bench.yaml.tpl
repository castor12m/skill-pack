# bench.yaml — generated by `skillpack bench init`
# Docs: https://github.com/castor12m/skill-pack

# Model to test (same model for both vanilla and skill-applied runs)
model: claude-sonnet-4-20250514

# Path to the skill file (relative to this file)
skill_path: ./SKILL.md

# Number of runs per task (use >1 for median scoring)
runs: 1

# Maximum cost in USD (abort if exceeded). Use --no-limit to remove.
cost_cap_usd: 5.0

# Concurrent API calls (increase for large task sets)
# concurrency: 5

# Judge model (defaults to same as model if omitted)
# judge:
#   model: claude-sonnet-4-20250514

tasks:
  - name: example-task
    user: "Review this Python function for bugs and suggest improvements."
    # context_files:
    #   - fixtures/example.py
    assertions:
      - type: llm-judge
        rubric: |
          1: No useful feedback
          2: Identifies obvious issues only
          3: Identifies most issues with some suggestions
          4: Thorough review with actionable suggestions
          5: Expert-level review with prioritized, specific fixes
        min_score: 3
      # - type: contains
      #   value: "def "
